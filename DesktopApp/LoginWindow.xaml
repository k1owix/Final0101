<Window x:Class="DesktopApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="273" Width="412"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Вход в систему" FontSize="18" FontWeight="Bold" 
                   Foreground="Orange" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Text="Логин:" Margin="0,0,0,3"/>
        <TextBox x:Name="LoginTextBox" Margin="0,0,0,10" Padding="5"/>

        <TextBlock Text="Пароль:" Margin="0,0,0,3"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,15" Padding="5"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="LoginButton" Content="Войти" 
                    Background="Orange" Foreground="White" 
                    Padding="30,8" Click="BtnLogin_Click" Margin="0,0,10,0"/>
            <Button x:Name="CancelButton" Content="Отмена" 
                    Background="Gray" Foreground="White" 
                    Padding="30,8" Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>