<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читайте город - каталог"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        Icon="/Resources/icon.ico"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="8"
                Background="{StaticResource SecondaryBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="/Resources/logo.png"
                       Height="56"
                       Width="220"
                       Stretch="Uniform"
                       Margin="0,0,16,0" />

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="Книжный терминал"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Каталог и оформление заказов"
                               FontSize="14"
                               Foreground="White"
                               Opacity="0.95" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabel"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Гость" />
                    <Button x:Name="LoginButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="LoginButton_Click"
                            Content="Войти" />
                    <Button x:Name="LogoutButton"
                            Margin="8,0,0,0"
                            Click="LogoutButton_Click"
                            Content="Выйти"
                            Visibility="Collapsed" />
                    <Button x:Name="CartButton"
                            Margin="8,0,0,0"
                            Click="CartButton_Click"
                            Content="Корзина"
                            Visibility="Collapsed" />
                    <Button x:Name="ManageOrdersButton"
                            Margin="8,0,0,0"
                            Click="ManageOrdersButton_Click"
                            Content="Заказы"
                            Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="16"
                CornerRadius="8"
                Background="White"
                BorderBrush="#E5E0D6"
                BorderThickness="1">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Поиск" Style="{StaticResource FilterLabelStyle}" />
                    <TextBox x:Name="SearchTextBox"
                             Width="220"
                             TextChanged="OnFilterChanged" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Издательство" Style="{StaticResource FilterLabelStyle}" />
                    <ComboBox x:Name="ManufacturerComboBox"
                              Width="220"
                              SelectionChanged="OnFilterChanged" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Цена от" Style="{StaticResource FilterLabelStyle}" />
                    <TextBox x:Name="MinPriceTextBox"
                             Width="120"
                             TextChanged="OnFilterChanged" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Цена до" Style="{StaticResource FilterLabelStyle}" />
                    <TextBox x:Name="MaxPriceTextBox"
                             Width="120"
                             TextChanged="OnFilterChanged" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Сортировка" Style="{StaticResource FilterLabelStyle}" />
                    <ComboBox x:Name="SortComboBox"
                              Width="160"
                              SelectionChanged="OnFilterChanged">
                        <ComboBoxItem IsSelected="True" Content="Наименование" />
                        <ComboBoxItem Content="Цена" />
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="DescCheckBox"
                          Margin="0,24,0,0"
                          VerticalAlignment="Center"
                          Checked="OnFilterChanged"
                          Unchecked="OnFilterChanged"
                          Content="По убыванию" />
            </WrapPanel>
        </Border>

        <TextBlock x:Name="CountTextBlock"
                   Grid.Row="2"
                   Margin="4,12,0,0"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="Показано: 0 из 0" />

        <ScrollViewer Grid.Row="3"
                      Margin="0,12,0,0"
                      VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="ProductsPanel" />
        </ScrollViewer>
    </Grid>
</Window>
