<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="950">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== ВЕРХНЯЯ ПАНЕЛЬ ===== -->
        <StackPanel Grid.Row="0" Background="Orange" Orientation="Horizontal" Margin="10">
            <TextBlock Text="Магазин" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Width="200"/>
            <TextBlock x:Name="UserLabel" Text="Гость" Foreground="White" VerticalAlignment="Center" Margin="500,0,10,0"/>
            <Button x:Name="LoginButton" Content="Войти" Background="#B8860B" Foreground="White" 
                    Padding="10,3" Click="LoginButton_Click"/>
            <Button x:Name="LogoutButton" Content="Выйти" Background="#B8860B" Foreground="White" 
                    Padding="10,3" Click="LogoutButton_Click" Visibility="Collapsed"/>
            <Button x:Name="CartButton" Content="Корзина" Background="#B8860B" Foreground="White" 
                    Padding="10,3" Click="CartButton_Click" Margin="10,0,0,0" Visibility="Collapsed"/>
            <Button x:Name="ManageOrdersButton" Content="Управление заказами" Background="#B8860B" 
                    Foreground="White" Padding="10,3" Click="ManageOrdersButton_Click" Visibility="Collapsed" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- ===== ПАНЕЛЬ ФИЛЬТРОВ ===== -->
        <StackPanel Grid.Row="1" Margin="10">
            <WrapPanel>
                <TextBox x:Name="SearchTextBox" Width="150" TextChanged="OnFilterChanged" Margin="0,0,10,0"/>
                <ComboBox x:Name="ManufacturerComboBox" Width="150" SelectionChanged="OnFilterChanged" Margin="0,0,10,0"/>
                <TextBox x:Name="MinPriceTextBox" Width="60" Text="0" TextChanged="OnFilterChanged" Margin="0,0,5,0"/>
                <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="MaxPriceTextBox" Width="60" Text="100000" TextChanged="OnFilterChanged" Margin="0,0,10,0"/>
                <ComboBox x:Name="SortComboBox" Width="100" SelectionChanged="OnFilterChanged">
                    <ComboBoxItem Content="Имя" IsSelected="True"/>
                    <ComboBoxItem Content="Цена"/>
                </ComboBox>
                <CheckBox x:Name="DescCheckBox" Content="Убывание" Checked="OnFilterChanged" 
                          Unchecked="OnFilterChanged" Margin="10,0,10,0"/>
                <TextBlock x:Name="CountTextBlock" Text="Найдено: 0" FontWeight="Bold" VerticalAlignment="Center"/>
            </WrapPanel>
        </StackPanel>

        <!-- ===== ТОВАРЫ ===== -->
        <ScrollViewer Grid.Row="2">
            <WrapPanel x:Name="ProductsPanel" Margin="10"/>
        </ScrollViewer>
    </Grid>
</Window>
