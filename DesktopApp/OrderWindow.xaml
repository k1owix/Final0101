<Window x:Class="DesktopApp.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Корзина" Height="450" Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Моя корзина" FontSize="20" FontWeight="Bold" 
                   Foreground="Orange" Margin="0,0,0,10"/>

        <ListView x:Name="ItemsListView" Grid.Row="1" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Товар" Width="250" DisplayMemberBinding="{Binding Product.Name}"/>
                    <GridViewColumn Header="Кол-во" Width="80" DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Цена" Width="100" DisplayMemberBinding="{Binding Total, StringFormat={}{0:C}}"/>
                    <GridViewColumn>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="RemoveButton" Content="Удалить" Background="Red" Foreground="White" BorderThickness="0" 
                    Click="RemoveButton_Click"  Tag="{Binding}" Width="Auto" Height="25"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView> 
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <TextBlock Text="Итого:" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBlock x:Name="TotalTextBlock" FontSize="16" FontWeight="Bold" Foreground="#B8860B"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OrderButton" Content="Оформить заказ" 
                    Background="Orange" Foreground="White" 
                    Padding="20,8" Click="OrderButton_Click" Margin="0,0,10,0"/>
            <Button x:Name="CloseButton" Content="Закрыть" 
                    Background="Gray" Foreground="White" 
                    Padding="20,8" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>