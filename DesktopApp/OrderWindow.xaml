<Window x:Class="DesktopApp.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читайте город - заказ"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        Icon="/Resources/icon.ico"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="22"
                   FontWeight="Bold"
                   Text="Текущий заказ" />

        <TextBlock x:Name="CustomerTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,12"
                   Foreground="#5A5A5A"
                   Text="Покупатель: гость" />

        <ListView x:Name="ItemsListView"
                  Grid.Row="2"
                  Margin="0,0,0,12">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="250"
                                    Header="Товар"
                                    DisplayMemberBinding="{Binding Product.Name}" />
                    <GridViewColumn Width="150"
                                    Header="Издательство"
                                    DisplayMemberBinding="{Binding Product.ManufacturerName}" />
                    <GridViewColumn Width="90"
                                    Header="Количество"
                                    DisplayMemberBinding="{Binding Quantity}" />
                    <GridViewColumn Width="120"
                                    Header="Сумма"
                                    DisplayMemberBinding="{Binding Total, StringFormat={}{0:C}}" />
                    <GridViewColumn Width="120"
                                    Header="Действие">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Click="RemoveButton_Click"
                                        Content="Удалить"
                                        Tag="{Binding}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12">
            <TextBlock Margin="0,0,8,0"
                       FontSize="16"
                       FontWeight="Bold"
                       Text="Итого:" />
            <TextBlock x:Name="TotalTextBlock"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,8,0"
                    Click="CloseButton_Click"
                    Content="Закрыть" />
            <Button Style="{StaticResource AccentButtonStyle}"
                    Click="OrderButton_Click"
                    Content="Оформить заказ" />
        </StackPanel>
    </Grid>
</Window>
