<Window x:Class="DesktopApp.OrderManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление заказами" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление заказами" FontSize="20" FontWeight="Bold" 
                   Foreground="Orange" Margin="0,0,0,10"/>

        <ListView x:Name="OrdersListView" Grid.Row="1" Margin="0,0,0,10" SelectionChanged="OrdersListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="№" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Дата" Width="120" DisplayMemberBinding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                    <GridViewColumn Header="Клиент" Width="150" DisplayMemberBinding="{Binding CustomerName}"/>
                    <GridViewColumn Header="Статус" Width="120" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Код" Width="80" DisplayMemberBinding="{Binding PickupCode}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="StatusComboBox" Width="120" Margin="0,0,15,0">
                <ComboBoxItem Content="Новый"/>
                <ComboBoxItem Content="В обработке"/>
                <ComboBoxItem Content="Завершен"/>
            </ComboBox>
            <Button x:Name="UpdateButton" Content="Обновить" 
                    Background="Orange" Foreground="White" 
                    Padding="15,5" Click="UpdateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>