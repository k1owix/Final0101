<Window x:Class="DesktopApp.OrderManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читайте город - управление заказами"
        Width="980"
        Height="620"
        MinWidth="880"
        MinHeight="560"
        Icon="/Resources/icon.ico"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   FontSize="22"
                   FontWeight="Bold"
                   Text="Управление заказами" />

        <DataGrid x:Name="OrdersDataGrid"
                  Grid.Row="1"
                  Margin="0,0,0,12"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionChanged="OrdersDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Width="90" Header="№ заказа" Binding="{Binding OrderNumber}" />
                <DataGridTextColumn Width="120" Header="Дата" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" />
                <DataGridTextColumn Width="140" Header="Доставка" Binding="{Binding DeliveryDate, StringFormat={}{0:dd.MM.yyyy}}" />
                <DataGridTextColumn Width="250" Header="Клиент" Binding="{Binding ClientName}" />
                <DataGridTextColumn Width="130" Header="Статус" Binding="{Binding StatusName}" />
                <DataGridTextColumn Width="120" Header="Сумма" Binding="{Binding TotalAmount, StringFormat='{}{0:N2} ₽'}" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="OrderDetailsTextBlock"
                       Grid.Column="0"
                       Margin="0,0,16,0"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Foreground="#555555"
                       Text="Выберите заказ, чтобы посмотреть состав и обновить его параметры." />

            <DatePicker x:Name="DeliveryDatePicker"
                        Grid.Column="1"
                        Width="150"
                        Margin="0,0,12,0" />

            <ComboBox x:Name="StatusComboBox"
                      Grid.Column="2"
                      Width="160"
                      Margin="0,0,12,0">
                <ComboBoxItem Content="Новый" />
                <ComboBoxItem Content="В обработке" />
                <ComboBoxItem Content="Завершен" />
            </ComboBox>

            <Button Grid.Column="3"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="UpdateButton_Click"
                    Content="Сохранить" />
        </Grid>

        <TextBlock Grid.Row="3"
                   Foreground="#666666"
                   Text="Изменение статуса и даты доставки доступно только менеджеру и администратору." />
    </Grid>
</Window>
